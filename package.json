{
  "name": "ast-grep-tree-sitter-dart",
  "version": "0.0.5",
  "description": "ast-grep language support for Dart using UserNobody14/tree-sitter-dart for tree-sitter-dart",
  "main": "index.js",
  "scripts": {
    "build": "tree-sitter build -o parser.so",
    "source": "node nursery.js source",
    "prepublishOnly": "node nursery.js source",
    "postinstall": "node postinstall.js",
    "clean": "rm ./parser.*; rm ./scanner.*",
    "test": "node nursery.js test"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "type.d.ts",
    "postinstall.js",
    "src",
    "prebuilds"
  ],
  "keywords": [
    "ast-grep",
    "ast-grep-lang"
  ],
  "author": "Kevin Xiao",
  "license": "MIT",
  "dependencies": {
    "@ast-grep/setup-lang": "0.0.6"
  },
  "peerDependencies": {
    "tree-sitter-cli": "~0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter-cli": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ast-grep/nursery": "0.0.9",
    "node-gyp": "^12.2.0",
    "tree-sitter-cli": "~0.25.0",
    "tree-sitter-dart": "github:UserNobody14/tree-sitter-dart"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ast-grep-tree-sitter-dart",
      "tree-sitter",
      "tree-sitter-cli",
      "tree-sitter-dart"
    ]
  }
}
